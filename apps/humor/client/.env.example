# Client-side .env for apps/humor/client. Copy to .env and fill in
# CLIENT_PRIVATE_KEY. The server runs in a sibling directory; point
# RESOURCE_URL at it (default below assumes the server is on
# localhost:3000 with the /joke endpoint).
#
# Never commit a real .env.

# ── Required ────────────────────────────────────────────────────────
# Funded Mezo Testnet wallet that pays for /joke requests.
# Must hold testnet mUSD. See the README for funding instructions.
CLIENT_PRIVATE_KEY=0xYourClientPrivateKeyHere

# ── Network (defaults match Mezo Testnet; override if needed) ──────
# CAIP-2 chain identifier. Mezo Testnet = eip155:31611.
# Token info (address, decimals, name, version) auto-resolved from
# @x402/evm DEFAULT_STABLECOINS based on NETWORK.
NETWORK=eip155:31611

# Mezo Testnet RPC endpoint.
RPC_URL=https://rpc.test.mezo.org

# Mezo Testnet block explorer — used for tx/address links in client output.
EXPLORER_URL=https://explorer.test.mezo.org

# ── Resource ────────────────────────────────────────────────────────
# URL of the paywalled resource. Point at your local humor server
# (default), or at a hosted demo for a quick check.
RESOURCE_URL=http://localhost:3000/joke
