# Mezo Testnet (chain 31611) configuration — copy to .env for each of
# apps/humor/server and apps/humor/client. Never commit a real .env.

# ── Network ─────────────────────────────────────────────────────────
# CAIP-2 chain identifier. Mezo Testnet = eip155:31611.
NETWORK=eip155:31611

# Mezo Testnet RPC endpoint.
RPC_URL=https://rpc.test.mezo.org

# mUSD token on Mezo Testnet (public on-chain address, safe to keep as-is).
MUSD_ADDRESS=0x118917a40FAF1CD7a13dB0Ef56C86De7973Ac503

# ── Facilitator ─────────────────────────────────────────────────────
# Hosted Mezo-capable facilitator. No local setup needed.
FACILITATOR_URL=https://facilitator.vativ.io

# ── Server (apps/humor/server) ──────────────────────────────────────
# The address that receives mUSD payments for paywalled jokes.
# Use any address you control — it does NOT need a private key, only
# the client side signs.
EVM_ADDRESS=0xYourEvmAddressHere

# Port the humor server listens on.
PORT=3000

# ── Client (apps/humor/client) ──────────────────────────────────────
# Funded Mezo Testnet wallet that pays for /joke requests.
# Must hold testnet mUSD. See the README for funding instructions.
CLIENT_PRIVATE_KEY=0xYourClientPrivateKeyHere

# URL of the paywalled resource. Point at your local humor server,
# or at the hosted demo for a quick check.
RESOURCE_URL=http://localhost:3000/joke
