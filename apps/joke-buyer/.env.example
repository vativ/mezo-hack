# Mezo Testnet (chain 31611) configuration for the agentic joke-buyer.
# Copy to .env and fill in the private key. Never commit a real key.

# ── Network (defaults are fine for Mezo Testnet) ────────────────────
NETWORK=eip155:31611
RPC_URL=https://rpc.test.mezo.org
EXPLORER_URL=https://explorer.test.mezo.org
FACILITATOR_URL=https://facilitator.vativ.io

# ── Contracts (public on-chain addresses, safe to keep as-is) ──────
# mUSD token on Mezo Testnet.
MUSD_ADDRESS=0x118917a40FAF1CD7a13dB0Ef56C86De7973Ac503
# Canonical Permit2 (same address across all EVM chains).
PERMIT2_ADDRESS=0x000000000022D473030F116dDEE9F6B43aC78BA3

# ── Wallet ──────────────────────────────────────────────────────────
# Funded Mezo Testnet wallet that pays for /joke requests.
# Must hold testnet mUSD (see humor README for how to get some).
CLIENT_PRIVATE_KEY=0xYourClientPrivateKeyHere
# CLIENT_ADDRESS is derived from CLIENT_PRIVATE_KEY at runtime — no need to set it.
# To compute it manually: `cast wallet address --private-key $CLIENT_PRIVATE_KEY`

# ── Target ──────────────────────────────────────────────────────────
# The paywalled resource the agent buys from in a loop.
RESOURCE_URL=https://demo.vativ.io/joke

# How many jokes to buy per run. Also overridable via --count <N> on the CLI.
COUNT=3
