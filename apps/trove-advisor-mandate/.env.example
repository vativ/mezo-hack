# Mezo Testnet (chain 31611) configuration for the trove-mandate demo (Demo 3).
# Copy to .env and fill in the two secrets. Never commit a real key.

# ── Network ─────────────────────────────────────────────────────────
NETWORK=eip155:31611
RPC_URL=https://rpc.test.mezo.org
EXPLORER_URL=https://explorer.test.mezo.org
FACILITATOR_URL=https://facilitator.vativ.io

# ── Contracts (public on-chain addresses, safe to keep as-is) ──────
# mUSD token on Mezo Testnet.
MUSD_ADDRESS=0x118917a40FAF1CD7a13dB0Ef56C86De7973Ac503
# Canonical Permit2 (same address across all EVM chains).
PERMIT2_ADDRESS=0x000000000022D473030F116dDEE9F6B43aC78BA3

# ── Server ──────────────────────────────────────────────────────────
PORT=4402
SKIP_ORACLE=0x7b7c000000000000000000000000000000000015
SORTED_TROVES=0x722E4D24FD6Ff8b0AC679450F3D91294607268fA
TROVE_MANAGER=0xE47c80e8c23f6B4A1aE41c34837a0599D5D16bb0

# ── Merchants (distinct payTo per endpoint — same as Demo 2) ──
ORACLE_PAYTO=0xca66faaea61365bd94da74bcbfa86518e30dccab
RISK_PAYTO=0x7f6ac6a84783b44c59238a7f950a3ccfafdbc0f6
HUNTER_PAYTO=0x92cc276667ab0efcab4b021d0cb5d0669b993cdb

# ── Agent ───────────────────────────────────────────────────────────
CLIENT_PRIVATE_KEY=0xYourClientPrivateKeyHere
# CLIENT_ADDRESS is derived from CLIENT_PRIVATE_KEY at runtime — no need to set it.
# To compute it manually: `cast wallet address --private-key $CLIENT_PRIVATE_KEY`
ANTHROPIC_API_KEY=sk-ant-...
TROVE_ADVISOR_URL=http://localhost:4402

# Optional — override the Claude model (defaults to claude-sonnet-4-6).
# ANTHROPIC_MODEL=claude-sonnet-4-6
